# Zoho Mail SMTP for /api/contact
# Custom domain (hello@momentous.marketing) → usually smtppro.zoho.com
# Personal @zohomail.com → smtp.zoho.com
SMTP_HOST=smtppro.zoho.com
SMTP_PORT=587
SMTP_USER=hello@momentous.marketing
SMTP_PASS=
CONTACT_TO_EMAIL=hello@momentous.marketing

# Shadcnblocks Pro — https://shadcnblocks.com/dashboard/api
SHADCNBLOCKS_API_KEY=
